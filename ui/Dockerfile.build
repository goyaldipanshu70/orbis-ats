# Stage 1: Build React app with env variable
FROM node:22-alpine AS builder

WORKDIR /app

# Copy dependencies files and install
COPY package*.json ./
RUN npm install

# Copy the rest of the app code
COPY . .

# Inject build-time environment variable
ARG VITE_API_BASE_URL
RUN echo "VITE_API_BASE_URL=${VITE_API_BASE_URL}" > .env

# Run build (assumes Vite or similar build tool)
RUN npm run build

# The dist folder will now contain the built React app
