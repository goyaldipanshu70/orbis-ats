# Database
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/orbis_workflows

# JWT (must match svc-auth)
SECRET_KEY=your-secret-key
ALGORITHM=HS256

# LLM Providers (at least one required for AI nodes)
DEFAULT_LLM_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514
GOOGLE_API_KEY=
GOOGLE_MODEL=gemini-2.0-flash

# Search APIs
TAVILY_API_KEY=
GITHUB_TOKEN=

# Internal services
RECRUITING_URL=http://localhost:8002
INTERNAL_API_KEY=intesa-internal-key-dev
FRONTEND_URL=http://localhost:80
REDIS_URL=redis://localhost:6379

# Execution limits
MAX_CONCURRENT_RUNS=5
NODE_TIMEOUT_SECONDS=120
MAX_WORKFLOW_NODES=50
MAX_LEADS_PER_NODE=500

# Server
PORT=8015
